# Copy this file to .env for local development
# On Railway, set these under your service → Variables tab

# ── PRIMARY PROVIDER (required — at least one must be set) ──────────────────

# Groq — free tier, get key at: https://console.groq.com/keys
# Used for: openai/gpt-oss-120b (primary) + llama-3.1-8b-instant (last resort)
GROQ_API_KEY=gsk_...

# Cerebras — free tier, get key at: https://cloud.cerebras.ai → API Keys
# Used for: gpt-oss-120b (fallback #2)
CEREBRAS_API_KEY=csk-...

# SambaNova — free tier, get key at: https://cloud.sambanova.ai → API Authorization
# Used for: gpt-oss-120b (fallback #3)
SAMBANOVA_API_KEY=...

# Gemini — free tier, get key at: https://aistudio.google.com/app/apikey
# Used for: gemini-2.5-flash-lite (fallback #4)
GEMINI_API_KEY=AIza...

# ── DEPLOYMENT ──────────────────────────────────────────────────────────────

# Required in production — set to your Railway public URL
CLIENT_ORIGIN=https://your-app.up.railway.app

# ── OPTIONAL ────────────────────────────────────────────────────────────────

# PostgreSQL — for future persistence features
DATABASE_URL=postgresql://...

# Set automatically by Railway — do not set manually
# PORT=3000
# NODE_ENV=production
